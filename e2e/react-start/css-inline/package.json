{
  "name": "tanstack-react-start-e2e-css-inline",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "pnpm build:vite && pnpm build:rsbuild",
    "build:vite": "vite build && tsc --noEmit",
    "build:rsbuild": "rsbuild build && tsc --noEmit",
    "start": "node server.js",
    "test:e2e:vite": "E2E_TOOLCHAIN=vite playwright test --project=chromium",
    "test:e2e:rsbuild": "E2E_TOOLCHAIN=rsbuild playwright test --project=chromium",
    "test:e2e": "pnpm run test:e2e:vite && pnpm run test:e2e:rsbuild"
  },
  "dependencies": {
    "@tanstack/react-router": "workspace:^",
    "@tanstack/react-start": "workspace:^",
    "express": "^5.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "srvx": "^0.11.9"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.1",
    "@rsbuild/core": "^2.0.0",
    "@rsbuild/plugin-react": "^2.0.0",
    "@tanstack/router-e2e-utils": "workspace:^",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.0"
  },
  "nx": {
    "targets": {
      "test:e2e": {
        "parallelism": false
      }
    },
    "metadata": {
      "playwrightModes": [
        {
          "toolchain": "vite",
          "mode": "ssr"
        },
        {
          "toolchain": "rsbuild",
          "mode": "ssr"
        }
      ]
    }
  }
}
