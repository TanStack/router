{
  "name": "tanstack-react-start-e2e-custom-server-rsbuild",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx express-server.ts",
    "dev:e2e": "cross-env NODE_ENV=development tsx express-server.ts",
    "build": "rsbuild build && tsc --noEmit",
    "start": "tsx express-server.ts",
    "test:e2e:dev": "cross-env MODE=dev playwright test --project=chromium",
    "test:e2e:prod": "cross-env MODE=prod playwright test --project=chromium",
    "test:e2e": "rm -rf port*.txt && pnpm run test:e2e:dev && pnpm run test:e2e:prod"
  },
  "dependencies": {
    "@tanstack/react-router": "workspace:^",
    "@tanstack/react-start": "workspace:^",
    "express": "^5.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.1",
    "@rsbuild/core": "2.0.0",
    "@rsbuild/plugin-react": "2.0.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@tanstack/router-e2e-utils": "workspace:^",
    "@types/express": "^5.0.3",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "cross-env": "^10.0.0",
    "srvx": "^0.11.9",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.20.3",
    "typescript": "^6.0.2"
  }
}
