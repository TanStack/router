{
  "name": "tanstack-react-start-e2e-import-protection",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "pnpm dev:vite --port 3000",
    "dev:e2e": "pnpm dev:vite",
    "dev:vite": "vite dev",
    "dev:rsbuild": "rsbuild dev",
    "build": "pnpm build:vite",
    "build:vite": "vite build && tsc --noEmit",
    "build:rsbuild": "rsbuild build && tsc --noEmit",
    "start": "node server.js",
    "test:e2e:mockMode": "rm -rf node_modules/.vite; rm -rf port*.txt; playwright test --project=chromium",
    "test:e2e:errorMode": "rm -rf node_modules/.vite; rm -rf port*.txt; BEHAVIOR=error playwright test --project=chromium",
    "test:e2e": "pnpm run test:e2e:mockMode && pnpm run test:e2e:errorMode"
  },
  "dependencies": {
    "@tanstack/react-router": "workspace:^",
    "@tanstack/react-start": "workspace:^",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-tweet": "^3.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.1",
    "@rsbuild/core": "^2.0.1",
    "@rsbuild/plugin-react": "^2.0.0",
    "@tanstack/router-e2e-utils": "workspace:^",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^6.0.1",
    "srvx": "^0.11.9",
    "typescript": "^6.0.2",
    "vite": "^8.0.14"
  },
  "nx": {
    "targets": {
      "test:e2e": {
        "parallelism": false
      },
      "test:e2e--vite-ssr": {
        "parallelism": false
      },
      "test:e2e--vite-ssr--bundled-dev": {
        "parallelism": false
      },
      "test:e2e--rsbuild-ssr": {
        "parallelism": false
      }
    },
    "metadata": {
      "playwrightModes": [
        {
          "toolchain": "vite",
          "mode": "ssr",
          "env": {
            "E2E_VITE_BUNDLED_DEV": "false"
          }
        },
        {
          "toolchain": "vite",
          "mode": "ssr",
          "name": "bundled-dev",
          "env": {
            "E2E_VITE_BUNDLED_DEV": "true"
          }
        },
        {
          "toolchain": "rsbuild",
          "mode": "ssr"
        }
      ]
    }
  }
}
