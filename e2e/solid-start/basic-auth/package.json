{
  "name": "tanstack-solid-start-e2e-basic-auth",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3000",
    "dev:e2e": "vite dev",
    "build": "vite build && tsc --noEmit",
    "preview": "vite preview",
    "start": "pnpx srvx --prod -s ../client dist/server/server.js",
    "prisma-generate": "prisma generate",
    "test:e2e": "rm -rf port*.txt; mkdir -p .tmp; rm -f .tmp/dev.db .tmp/dev.db-journal .tmp/dev.db-wal .tmp/dev.db-shm; export DATABASE_URL=file:./.tmp/dev.db; pnpm run prisma-generate && pnpm exec prisma migrate deploy && playwright test --project=chromium"
  },
  "dependencies": {
    "@libsql/client": "^0.17.3",
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tanstack/solid-router": "workspace:^",
    "@tanstack/solid-router-devtools": "workspace:^",
    "@tanstack/solid-start": "workspace:^",
    "redaxios": "^0.5.1",
    "solid-js": "^1.9.13",
    "tailwind-merge": "^2.6.1",
    "vite": "^8.0.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/router-e2e-utils": "workspace:^",
    "@types/node": "^22.10.2",
    "dotenv": "^17.4.2",
    "prisma": "^7.8.0",
    "srvx": "^0.11.15",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.2",
    "vite-plugin-solid": "^2.11.12"
  }
}
