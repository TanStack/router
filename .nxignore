# Solid v2 migration: temporarily excluded apps.
#
# These apps depend on third-party packages that do not yet support SolidJS v2
# (solid-js@2.x). They cannot build against the v2 catalog and are excluded from
# the Nx graph (build + e2e) until the upstream deps ship Solid v2 support.
# Re-include each one by deleting its line once its blocking dep is Solid-2 ready.

# solid-motionone (peer solid-js ^1.8.0, no Solid 2 release)
examples/solid/with-framer-motion

# convex-solidjs@0.0.3 (peer solid-js ^1.6.0, imports solid-js/web)
examples/solid/start-convex-better-auth

# @tanstack/solid-virtual (no Solid 2 release; imports solid-js/store)
examples/solid/scroll-restoration
e2e/solid-router/basic-scroll-restoration

# @tanstack/solid-devtools@0.7.0 (devtools shell, peer solid-js >=1.9.7)
examples/solid/start-bun
examples/solid/start-i18n-paraglide

# @sentry/solid@10.x (imports splitProps from solid-js)
e2e/solid-router/sentry-integration
