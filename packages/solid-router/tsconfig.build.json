{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "moduleResolution": "Bundler",
    "rootDir": "src",
    "isolatedDeclarations": true,
    "allowJs": false,
    "checkJs": false,
    "declarationDir": "dist/esm",
    "noEmit": false,
    "composite": true,
    "declaration": true,
    "emitDeclarationOnly": true,
  },
  "include": ["src"]
}
