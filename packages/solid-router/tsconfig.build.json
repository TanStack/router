{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "jsx": "preserve",
    "jsxImportSource": "@solidjs/web",
    "moduleResolution": "Bundler",
    "rootDir": "src",
    "outDir": "dist/source",
    "noEmit": false,
    "declaration": true,
    "sourceMap": true
  },
  "include": ["src"]
}
