{
  "name": "@tanstack/start-client-core",
  "version": "1.167.13",
  "description": "Modern and scalable routing for React applications",
  "author": "Tanner Linsley",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TanStack/router.git",
    "directory": "packages/start-client-core"
  },
  "homepage": "https://tanstack.com/start",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/tannerlinsley"
  },
  "keywords": [
    "react",
    "location",
    "router",
    "routing",
    "async",
    "async router",
    "typescript"
  ],
  "scripts": {
    "clean": "rimraf ./dist && rimraf ./coverage",
    "test": "pnpm test:eslint && pnpm test:types && pnpm test:build && pnpm test:unit",
    "test:unit": "vitest",
    "test:unit:dev": "vitest --watch",
    "test:eslint": "eslint ./src",
    "test:types": "pnpm run \"/^test:types:ts[0-9]{2}$/\"",
    "test:types:ts55": "node ../../node_modules/typescript55/lib/tsc.js",
    "test:types:ts56": "node ../../node_modules/typescript56/lib/tsc.js",
    "test:types:ts57": "node ../../node_modules/typescript57/lib/tsc.js",
    "test:types:ts58": "node ../../node_modules/typescript58/lib/tsc.js",
    "test:types:ts59": "node ../../node_modules/typescript59/lib/tsc.js",
    "test:types:ts60": "tsc",
    "test:build": "publint --strict && attw --ignore-rules no-resolution --pack .",
    "build": "vite build"
  },
  "type": "module",
  "types": "dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      }
    },
    "./client": {
      "import": {
        "types": "./dist/esm/client/index.d.ts",
        "default": "./dist/esm/client/index.js"
      }
    },
    "./client-rpc": {
      "import": {
        "types": "./dist/esm/client-rpc/index.d.ts",
        "default": "./dist/esm/client-rpc/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "imports": {
    "#tanstack-start-entry": {
      "default": "./dist/esm/fake-entries/start.js"
    },
    "#tanstack-router-entry": {
      "default": "./dist/esm/fake-entries/router.js"
    },
    "#tanstack-start-plugin-adapters": {
      "default": "./dist/esm/fake-entries/plugin-adapters.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "src",
    "skills",
    "bin",
    "!skills/_artifacts"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "dependencies": {
    "@tanstack/router-core": "workspace:*",
    "@tanstack/start-fn-stubs": "workspace:*",
    "@tanstack/start-storage-context": "workspace:*",
    "seroval": "^1.5.0"
  },
  "devDependencies": {
    "@tanstack/intent": "^0.0.14",
    "vite": "*",
    "@types/node": ">=20"
  },
  "bin": {
    "intent": "./bin/intent.js"
  }
}
