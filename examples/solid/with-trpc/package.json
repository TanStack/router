{
  "name": "tanstack-router-solid-example-with-trpc",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm tsx ./src/server/server.ts --watch",
    "build": "pnpm run build:server && pnpm run build:client",
    "build:client": "vite build && tsc --noEmit",
    "build:server": "vite build --mode server",
    "start": "NODE_ENV=production node dist/server/server.js"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/solid-router": "^1.170.4",
    "@tanstack/solid-router-devtools": "^1.167.0",
    "@tanstack/router-plugin": "^1.168.6",
    "@trpc/client": "^11.17.0",
    "@trpc/server": "^11.4.3",
    "express": "^4.22.2",
    "solid-js": "^1.9.13",
    "redaxios": "^0.5.1",
    "tailwindcss": "^4.3.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "vite-plugin-solid": "^2.11.12",
    "tsx": "^4.22.3",
    "vite": "^8.0.13"
  }
}
