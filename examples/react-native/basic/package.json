{
  "name": "tanstack-router-react-native-example",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "sh -c 'npx @tanstack/router-cli watch & expo start; kill $!'",
    "routes:generate": "npx @tanstack/router-cli generate",
    "routes:watch": "npx @tanstack/router-cli watch",
    "start": "npx @tanstack/router-cli generate && expo start",
    "android": "npx @tanstack/router-cli generate && expo run:android",
    "ios": "npx @tanstack/router-cli generate && expo run:ios",
    "web": "npx @tanstack/router-cli generate && expo start --web"
  },
  "dependencies": {
    "@tanstack/react-native-router": "^0.0.1",
    "expo": "~54.0.0",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/runtime": "^7.25.0",
    "@tanstack/router-cli": "^1.163.3",
    "@types/react": "~19.1.0",
    "typescript": "^5.9.3"
  },
  "private": true
}
