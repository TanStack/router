{
  "name": "tanstack-router-react-example-with-trpc-react-query",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm tsx ./src/server/server.ts --watch",
    "build": "pnpm run build:server && pnpm run build:client",
    "build:client": "vite build && tsc --noEmit",
    "build:server": "vite build --mode server",
    "start": "NODE_ENV=production node dist/server/server.js"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-query-devtools": "^5.101.0",
    "@tanstack/react-router": "^1.170.15",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/router-plugin": "^1.168.18",
    "@trpc/client": "^11.17.0",
    "@trpc/server": "^11.4.3",
    "@trpc/tanstack-react-query": "^11.17.0",
    "express": "^5.2.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "redaxios": "^0.5.1",
    "tailwindcss": "^4.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^6.0.2",
    "tsx": "^4.22.4",
    "vite": "^8.0.16"
  }
}
